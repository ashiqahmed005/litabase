# PostgreSQL password
POSTGRES_PASSWORD=litabase_secret

# JWT secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# AES-256 encryption key for stored DB passwords (exactly 32 chars)
ENCRYPTION_KEY=change-this-32char-key-prodxxxxx

# SMTP for scheduled report emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Litabase <you@gmail.com>
