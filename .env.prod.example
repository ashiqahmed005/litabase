# Production environment — copy to .env.prod and fill in real values
POSTGRES_PASSWORD=strong-random-password-here
JWT_SECRET=strong-random-jwt-secret-at-least-32-chars
ENCRYPTION_KEY=exactly-32-character-secret-key!

# SMTP for scheduled report emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Litabase <you@gmail.com>
